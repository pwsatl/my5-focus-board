{
  "manifest_version": 3,
  "name": "My5 Focus Board",
  "version": "1.3",
  "description": "Personal task board with My 5 priorities, drag-and-drop, and email parsing.",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open My5 Focus Board"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}